# Copy this file to `.env` for local use with a tool like `django-environ`
# or set these directly in your host's dashboard (Render/Railway/Vercel/
# Netlify all have an "Environment Variables" settings page).
# None of these are required for local `python manage.py runserver` --
# settings.py falls back to the original hard-coded dev values if unset.

# A long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-value

# "False" in every real deployment. Leave unset ("True") for local dev.
DJANGO_DEBUG=False

# Comma-separated list of hosts this app is allowed to serve, e.g.
#   myproject.onrender.com,myproject.up.railway.app,myproject.vercel.app
DJANGO_ALLOWED_HOSTS=.onrender.com,.up.railway.app,.vercel.app

# Comma-separated list of the full HTTPS origin(s) your app is deployed at
# (used for CSRF_TRUSTED_ORIGINS / CORS_ALLOWED_ORIGINS). Must include the
# scheme, e.g.:
DJANGO_EXTRA_ORIGINS=https://myproject.onrender.com

# Managed Postgres connection string. Required on Vercel/Netlify (their
# filesystem is ephemeral so SQLite cannot be used there); optional but
# recommended on Render/Railway. Most hosts inject this automatically when
# you attach a Postgres add-on/database.
#   postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=
